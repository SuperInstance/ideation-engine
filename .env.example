# Ideation Engine — Environment Variables
# Copy to .dev.vars for local dev, or use `wrangler secret put` for deploy

# DeepSeek (chat + reasoning)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# DeepInfra (Seed-2.0-pro, Seed-2.0-mini)
DEEPINFRA_API_KEY=your-deepinfra-key-here

# SiliconFlow (Seed-OSS-36B, etc.)
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
